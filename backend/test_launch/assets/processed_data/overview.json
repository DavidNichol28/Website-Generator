        {
          "Plain": {
            "String": "This project was created and is maintained under the umbrella of the "
          }
        },
        {
          "NexusPointer": {
            "text": "Rebuild Forge Foundation.",
            "link_type": "link",
            "pointer": "rebuild-forge.netlify.app"
          }
        },
        {
          "Plain": {
            "String": " - a collective effort to dismantle Techno-Feudalism and replace it with free tools built for people, not profit, in order to help bring about a Free, Open, and Accessible Public Digital Infrastructure."
